---
import NoStories from "@components/story/NoStories.astro";
import StoriesHeader from "@components/story/StoriesHeader/StoriesHeaderIsland";
import StorySummaryGrid from "@components/story/summary/grid/StorySummaryGrid.astro";
import { isNonEmptyArray } from "@util/nonEmptyArray";
import isStewardUser from "@authentication/isStewardUser";

import Layout from "../../../layouts/AuthoringLayout.astro";

import groupByPublicationStatus from "./_groupByPublicationStatus.js";

const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect("/login");
}
const isSteward = isStewardUser(
  user,
  Astro.request.headers.get("cookie"),
);
const stewardToggleEnabled =
  process.env.DEV_STEWARD_TOGGLE === "1" ||
  process.env.DEV_STEWARD_TOGGLE === "true";

const { repositoryStory, i18n } = Astro.locals.environment<
  App.WithStoryRepository & App.WithI18N
>();

let stories = await repositoryStory.getStorySummariesByAuthor(user.id);

if (!stories) {
  stories = {
    author: {
      id: user.id,
      name: user.name,
    },
    stories: [],
  };
}

const translations = i18n.getTranslationsForPage({
  locale: Astro.preferredLocale,
  page: "stories",
});

const [publishedStories, unpublishedStories] = groupByPublicationStatus(
  stories.stories,
);

const thereIsAtLeastOneStory = isNonEmptyArray(stories.stories);
---

<Layout
  title={i18n.t("page.stories.meta.title")}
  description={i18n.t("page.stories.meta.description")}
>
  <main>
    <StoriesHeader
      author={stories.author}
      translations={translations}
      showCreateStory={isNonEmptyArray(stories.stories)}
      client:only="react"
    />
    {(isSteward || stewardToggleEnabled) && (
      <div class="steward-banner">
        <a href="/author/steward">Open steward console</a>
        {stewardToggleEnabled && (
          <button
            type="button"
            class="steward-toggle"
            data-steward={isSteward ? "on" : "off"}
          >
            Steward: {isSteward ? "On" : "Off"}
          </button>
        )}
      </div>
    )}

    {!thereIsAtLeastOneStory && <NoStories translations={translations} />}

    {
      isNonEmptyArray(unpublishedStories) && (
        <StorySummaryGrid stories={unpublishedStories}>
          <h2 slot="header" class="header">
            Unpublished stories
          </h2>
          <div slot="blurb" class="blurb">
            These are the stories you're working on. Only you can see them.
          </div>
        </StorySummaryGrid>
      )
    }

    {
      isNonEmptyArray(publishedStories) && (
        <StorySummaryGrid stories={publishedStories}>
          <h2 slot="header" class="header">
            Published stories
          </h2>
          <div slot="blurb" class="blurb">
            These are all of your published stories. Anyone with the link to
            your published story can read it.
          </div>
        </StorySummaryGrid>
      )
    }
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    margin: 2rem auto;
    width: 1000px;
  }

  .header,
  .blurb {
    color: var(--color-text);
  }

  .steward-banner {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.75rem;
  }

  .steward-banner a {
    border: 1px solid #222;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    text-decoration: none;
    color: inherit;
  }

  .steward-toggle {
    border: 1px solid #1f4d7a;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: #e7f2ff;
    color: #1f4d7a;
    cursor: pointer;
  }
</style>

{stewardToggleEnabled && (
  <script is:inline>
    const toggle = document.querySelector(".steward-toggle");
    toggle?.addEventListener("click", () => {
      const isOn = toggle.dataset.steward === "on";
      if (isOn) {
        document.cookie =
          "vsat_steward=0; Path=/; Max-Age=0; SameSite=Lax";
      } else {
        document.cookie =
          "vsat_steward=1; Path=/; SameSite=Lax";
      }
      window.location.reload();
    });
  </script>
)}
