---
import PublishedStorySummaryView from "@components/story/published/PublishedStorySummary/PublishedStorySummary.astro";

import Layout from "../../layouts/PublicSiteLayout.astro";

const { i18n, log, repositoryStory } = Astro.locals.environment<
  App.WithI18N & App.WithLog & App.WithStoryRepository
>();

let allStories: Awaited<ReturnType<typeof repositoryStory.getPublishedStorySummaries>> =
  [];
let storyDataUnavailable = false;

try {
  allStories = await repositoryStory.getPublishedStorySummaries({});
} catch (err) {
  storyDataUnavailable = true;
  log.warn({ err }, "Public story index unavailable; rendering empty view");
}
---

<Layout
  title={i18n.t("page.site-stories.meta.title")}
  description={i18n.t("page.site-stories.meta.description")}
  pageName={"site-stories"}
>
  <header>
    <div class="stories-header">
      <div>
        <h1>{i18n.t("page.site-stories.heading.title")}</h1>
        <div class="strapline">
          {i18n.t("page.site-stories.heading.strapline")}
        </div>
      </div>
      <a class="vsatlatarium-link" href="/story/vsatlatarium">
        Open VSATLATARIUM
      </a>
    </div>
  </header>
  {storyDataUnavailable && (
    <p class="stories-notice">
      Story data is currently unavailable because the local database is not
      reachable. VSATLATARIUM will still open in offline mode.
    </p>
  )}
  <main class="stories">
    <div class="published">
      {allStories.length ? (
        allStories.map((story) => <PublishedStorySummaryView story={story} />)
      ) : (
        <p class="stories-empty">No published stories are available right now.</p>
      )}
    </div>
  </main>
</Layout>

<style>
  body {
    text-align: center;

    @media screen and (min-width: 1000px) {
      max-width: 75%;
      text-align: unset;
    }
  }

  header {
    margin: 1rem;
  }

  .stories-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .strapline {
    margin-top: 0.5rem;
    font-size: 1.5rem;
    font-style: italic;
  }

  .stories-notice {
    margin: 0 1rem 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid #c7d9ef;
    border-radius: 0.75rem;
    background: #f4f8fd;
    color: #1f3551;
  }

  .vsatlatarium-link {
    border: 1px solid #1f4d7a;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    background: #e7f2ff;
    color: #1f4d7a;
    text-decoration: none;
    white-space: nowrap;
  }

  .stories {
    display: grid;
    gap: 2rem;
    justify-content: center;
    margin-bottom: 1rem;

    .published {
      width: 1000px;
      margin: var(--margin);
      display: grid;
      gap: 2rem;
      justify-content: center;
    }

    @media screen and (min-width: 500px) {
      .published {
        grid-template-columns: 25rem 25rem;
      }
    }

    @media screen and (min-width: 1000px) {
      .published {
        grid-template-columns: 25rem 25rem 25rem;
      }
    }
  }

  .stories-empty {
    margin: 0;
    padding: 2rem 1rem;
    border: 1px dashed #aac1d8;
    border-radius: 0.75rem;
    background: #f9fbfd;
    color: #48627d;
  }
</style>
