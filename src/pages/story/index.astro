---
import PublishedStorySummaryView from "@components/story/published/PublishedStorySummary/PublishedStorySummary.astro";

import Layout from "../../layouts/PublicSiteLayout.astro";

const { i18n, repositoryStory } = Astro.locals.environment<
  App.WithI18N & App.WithStoryRepository
>();

const allStories = await repositoryStory.getPublishedStorySummaries({});
---

<Layout
  title={i18n.t("page.site-stories.meta.title")}
  description={i18n.t("page.site-stories.meta.description")}
  pageName={"site-stories"}
>
  <header>
    <div class="stories-header">
      <div>
        <h1>{i18n.t("page.site-stories.heading.title")}</h1>
        <div class="strapline">
          {i18n.t("page.site-stories.heading.strapline")}
        </div>
      </div>
      <a class="vsatlatarium-link" href="/story/vsatlatarium">
        Open VSATLATARIUM
      </a>
    </div>
  </header>
  <main class="stories">
    <div class="published">
      {allStories.map((story) => <PublishedStorySummaryView story={story} />)}
    </div>
  </main>
</Layout>

<style>
  body {
    text-align: center;

    @media screen and (min-width: 1000px) {
      max-width: 75%;
      text-align: unset;
    }
  }

  header {
    margin: 1rem;
  }

  .stories-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .strapline {
    margin-top: 0.5rem;
    font-size: 1.5rem;
    font-style: italic;
  }

  .vsatlatarium-link {
    border: 1px solid #1f4d7a;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    background: #e7f2ff;
    color: #1f4d7a;
    text-decoration: none;
    white-space: nowrap;
  }

  .stories {
    display: grid;
    gap: 2rem;
    justify-content: center;
    margin-bottom: 1rem;

    .published {
      width: 1000px;
      margin: var(--margin);
      display: grid;
      gap: 2rem;
      justify-content: center;
    }

    @media screen and (min-width: 500px) {
      .published {
        grid-template-columns: 25rem 25rem;
      }
    }

    @media screen and (min-width: 1000px) {
      .published {
        grid-template-columns: 25rem 25rem 25rem;
      }
    }
  }
</style>
